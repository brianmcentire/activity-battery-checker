# Garmin OAuth 1 credentials (from Garmin Developer Program)
GARMIN_CONSUMER_KEY=your-consumer-key
GARMIN_CONSUMER_SECRET=your-consumer-secret

# Application settings
DB_PATH=activity_battery.db
WEBHOOK_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# Debug: save downloaded FIT files to disk
SAVE_FIT_FILES=false
FIT_FILES_DIR=debug_fit_files
